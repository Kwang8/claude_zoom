{
  "name": "claude-zoom",
  "version": "0.1.0",
  "description": "Voice-first multi-agent Claude Code interface",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsc -p tsconfig.main.json --watch\" \"electron .\"",
    "build": "vite build && tsc -p tsconfig.main.json",
    "start": "npm run build && electron .",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json --watch"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
